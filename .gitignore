# Raw market data and Excel workbooks
data/
*.xlsx
*.xls
*.xlsm

# Ignore generic PDFs unless explicitly allowed below
*.pdf

# Allow project documentation/report PDFs
!docs/
!docs/*.pdf

# Allow original VBA source files
!original_vba/
!original_vba/*.bas

# Python cache
__pycache__/
*.pyc
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
env/

# Local configuration
.env

# Generated binary/intermediate files
*.pkl
*.joblib

# System files
.DS_Store
Thumbs.db